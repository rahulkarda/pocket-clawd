{
  "name": "pocket-claude",
  "version": "0.3.0",
  "description": "A pocket-sized Claude that lives in your macOS menubar — pixel-art mascot, time-aware chat, daily todos.",
  "main": "out/main/index.js",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/rahulkarda/pocket-claude",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahulkarda/pocket-claude.git"
  },
  "bugs": {
    "url": "https://github.com/rahulkarda/pocket-claude/issues"
  },
  "keywords": [
    "claude",
    "anthropic",
    "electron",
    "macos",
    "menubar",
    "tray",
    "ai-assistant",
    "pixel-art"
  ],
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "build:icons": "node scripts/build-icons.cjs",
    "start": "ELECTRON_RUN_AS_NODE= electron-vite preview",
    "package": "npm run build && ELECTRON_RUN_AS_NODE= electron-builder --mac --dir",
    "dist": "npm run build && ELECTRON_RUN_AS_NODE= electron-builder --mac",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.11.0",
    "keytar": "^7.9.0",
    "nanoid": "^3.3.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.45",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}
